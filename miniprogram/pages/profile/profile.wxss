.pf-wrap { padding: 100rpx 48rpx 80rpx; }
.logo { font-size: 48rpx; font-weight: 700; text-align: center; color: #0f1b33; letter-spacing: 2rpx; }
.sub { color: #7a8499; text-align: center; margin-top: 18rpx; font-size: 26rpx; line-height: 1.6; padding: 0 20rpx; }

.err-banner {
  margin-top: 40rpx; padding: 20rpx 28rpx;
  background: #fff8f0; border-radius: 16rpx; border-left: 6rpx solid #ff976a;
}
.err-banner text { font-size: 26rpx; color: #e65100; line-height: 1.6; }
.ok-banner {
  margin-top: 40rpx; padding: 20rpx 28rpx;
  background: #ecfdf3; border-radius: 16rpx; border-left: 6rpx solid #18a058;
}
.ok-banner text { font-size: 26rpx; color: #18a058; line-height: 1.6; }

.card {
  margin-top: 50rpx; padding: 48rpx 40rpx;
  background: #ffffff; border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(15,27,51,0.06);
}
.field { margin-top: 40rpx; }
.field:first-child { margin-top: 0; }
.field .lbl {
  display: block; font-size: 29rpx; color: #4a5568;
  margin-bottom: 18rpx; font-weight: 600; letter-spacing: 1rpx;
}
.field input {
  width: 100%; height: 108rpx; padding: 0 32rpx;
  background: #f8fafc; border: 2rpx solid #e2e8f0; border-radius: 18rpx;
  font-size: 32rpx; color: #1a202c; box-sizing: border-box;
}
.field input:focus { border-color: #2f6bff; background: #ffffff; }

.pf-btn {
  margin-top: 70rpx; border-radius: 50rpx; font-size: 33rpx; font-weight: 600;
  height: 100rpx; display: flex; align-items: center; justify-content: center;
  letter-spacing: 4rpx; box-shadow: 0 16rpx 36rpx -10rpx rgba(39,75,214,.5);
}
.skip-row { margin-top: 48rpx; text-align: center; }
.skip-text { font-size: 28rpx; color: #94a3b8; }
