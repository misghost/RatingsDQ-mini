<view class="login-wrap">
  <view class="logo">评级到期提醒</view>
  <view class="sub">登录后可查看个人专属到期提醒、上传合同数据</view>

  <!-- 错误提示 -->
  <view wx:if="{{errMsg && !showBind}}" class="err-banner">
    <text>{{errMsg}}</text>
  </view>

  <!-- 管理员切换 -->
  <view class="card role-card">
    <view class="role-row">
      <text>以管理员身份登录</text>
      <switch checked="{{isAdmin}}" bindchange="toggleRole" color="#07c160" />
    </view>
    <view class="muted sm">管理员可上传后台源数据、查看全员总览</view>
  </view>

  <!-- 主登录按钮（未显示绑定面板时） -->
  <block wx:if="{{!showBind}}">
    <button class="btn-primary login-btn" loading="{{loading}}" bindtap="doLogin">
      {{isAdmin ? '管理员登录' : '微信登录'}}
    </button>

    <view class="skip-row" bindtap="skipLogin">
      <text class="skip-text">暂不登录，先浏览</text>
    </view>

    <view class="skip-row" bindtap="goRegister">
      <text class="skip-text">还没有账号？去注册 ›</text>
    </view>

    <!-- 已有账号但微信登不上？绑定入口 -->
    <view wx:if="{{showBindHint}}" class="bind-hint" bindtap="openBind">
      <text class="bind-hint-text">已有注册账号？点此关联微信登录</text>
    </view>
  </block>

  <!-- 绑定已有账号面板 -->
  <block wx:if="{{showBind}}">
    <view class="card bind-card">
      <view class="bind-title">关联已有账号</view>
      <view class="bind-desc">输入注册时使用的「手机号 + 登录密码」，即可将账号与当前微信关联</view>

      <view class="field">
        <text class="lbl">手机号</text>
        <input type="number" maxlength="11" placeholder="注册时填写的手机号"
               value="{{bindPhone}}" bindinput="onBindPhone" />
      </view>

      <view class="field">
        <text class="lbl">密码</text>
        <input type="text" password placeholder="账号登录密码"
               value="{{bindPassword}}" bindinput="onBindPassword" />
      </view>

      <button class="btn-primary bind-btn" loading="{{binding}}" bindtap="doBind">
        关联并登录
      </button>

      <view class="skip-row" bindtap="closeBind">
        <text class="skip-text">← 返回登录</text>
      </view>
    </view>
  </block>
</view>
