.login-wrap { padding: 120rpx 48rpx 60rpx; }
.logo { font-size: 48rpx; font-weight: 600; text-align: center; }
.sub { color: #9aa0a6; text-align: center; margin-top: 16rpx; font-size: 26rpx; }
.role-card { margin-top: 60rpx; }
.role-row { display: flex; justify-content: space-between; align-items: center; }
.sm { font-size: 24rpx; margin-top: 12rpx; }

/* 按钮：flex 真居中，不用 line-height 猜 */
.login-btn {
  margin-top: 80rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.err-banner {
  margin-top: 30rpx; padding: 16rpx 24rpx;
  background: #fff3e0; border-radius: 12rpx;
  border-left: 6rpx solid #ff976a;
}
.err-banner text { font-size: 24rpx; color: #e65100; line-height: 1.5; }
.skip-row { margin-top: 40rpx; text-align: center; }
.skip-text { font-size: 28rpx; color: #9aa0a6; }

/* 绑定提示入口 */
.bind-hint {
  margin-top: 50rpx; padding: 24rpx 32rpx;
  background: #f0f5ff; border-radius: 16rpx;
  border: 2rpx solid #c4d5fc; text-align: center;
}
.bind-hint-text { font-size: 27rpx; color: #274bd6; font-weight: 500; }

/* 绑定面板 */
.bind-card {
  margin-top: 40rpx; padding: 48rpx 36rpx;
}
.bind-title { font-size: 34rpx; font-weight: 600; color: #0f1b33; text-align: center; }
.bind-desc {
  font-size: 25rpx; color: #7a8499; text-align: center;
  margin-top: 16rpx; line-height: 1.6;
}
.bind-card .field { margin-top: 32rpx; }
.bind-card .lbl {
  display: block; font-size: 28rpx; color: #7a8499;
  margin-bottom: 16rpx; font-weight: 600;
}
/* 绑定输入框：加大高度和内边距 */
.bind-card input {
  width: 100%; height: 100rpx; padding: 0 30rpx;
  background: #fbfcfe; border: 2rpx solid #e5e9f2; border-radius: 16rpx;
  font-size: 32rpx; color: #2b3245;
  box-sizing: border-box;
}
/* 绑定按钮：flex 真居中 */
.bind-btn {
  margin-top: 56rpx; border-radius: 48rpx;
  font-size: 32rpx; height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx -10rpx rgba(39,75,214,.55);
}
