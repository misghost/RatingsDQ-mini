.wrap { padding: 24rpx; }

.need-login {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 48rpx;
}
.nl-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.nl-title { font-size: 32rpx; font-weight: 600; color: #1f2329; margin-bottom: 12rpx; }
.nl-desc { font-size: 26rpx; color: #9aa0a6; margin-bottom: 40rpx; text-align: center; }
.btn-go-login {
  width: 400rpx; height: 80rpx; line-height: 80rpx;
  border-radius: 48rpx; font-size: 30rpx; background: #07c160; color: #fff;
}

.sec-title { font-size: 28rpx; font-weight: 600; margin: 8rpx 4rpx 16rpx; }

.row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 0; border-bottom: 1rpx solid #f0f1f2;
}
.row-main { display: flex; flex-direction: column; flex: 1; padding-right: 20rpx; }
.row-main .t { font-size: 30rpx; font-weight: 600; }
.row-main .d { font-size: 24rpx; color: #9aa0a6; margin-top: 6rpx; }

.field { margin-top: 20rpx; }
.field .lbl { display: block; font-size: 26rpx; color: #9aa0a6; margin-bottom: 10rpx; }
.field input {
  width: 100%; padding: 20rpx 24rpx; background: #fafbfc;
  border: 1rpx solid #e6e8eb; border-radius: 12rpx; font-size: 28rpx;
}

.btn-primary {
  margin-top: 40rpx; border-radius: 48rpx; font-size: 32rpx;
  height: 84rpx; line-height: 84rpx; background: #07c160; color: #fff;
}
.btn-ghost {
  margin-top: 20rpx; border-radius: 48rpx; font-size: 28rpx;
  height: 76rpx; line-height: 76rpx; background: #fff; color: #07c160;
  border: 1rpx solid #07c160;
}
.btn-grey {
  margin-top: 20rpx; border-radius: 48rpx; font-size: 28rpx;
  height: 76rpx; line-height: 76rpx; background: #eef0f2; color: #1f2329;
}

.sub-state { font-size: 26rpx; color: #07c160; margin: 16rpx 0; }
.muted { color: #9aa0a6; }
.sm { font-size: 24rpx; }

.msg {
  margin-top: 16rpx; padding: 16rpx 24rpx; font-size: 26rpx;
  color: #07c160; background: #e8f8ef; border-radius: 12rpx;
}
