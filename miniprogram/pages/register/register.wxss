.reg-wrap { padding: 100rpx 48rpx 80rpx; }
.logo { font-size: 52rpx; font-weight: 700; text-align: center; color: #0f1b33; letter-spacing: 2rpx; }
.sub {
  color: #7a8499; text-align: center; margin-top: 20rpx;
  font-size: 27rpx; line-height: 1.6; padding: 0 20rpx;
}

.err-banner {
  margin-top: 40rpx; padding: 20rpx 28rpx;
  background: #fff8f0; border-radius: 16rpx;
  border-left: 6rpx solid #ff976a;
}
.err-banner text { font-size: 26rpx; color: #e65100; line-height: 1.6; }

.card {
  margin-top: 50rpx; padding: 48rpx 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(15,27,51,0.06);
}

.field { margin-top: 36rpx; }
.field:first-child { margin-top: 0; }
.field .lbl {
  display: block; font-size: 28rpx; color: #4a5568;
  margin-bottom: 16rpx; font-weight: 600; letter-spacing: 1rpx;
}
.field input {
  width: 100%; height: 92rpx; padding: 0 30rpx;
  background: #f8fafc; border: 2rpx solid #e2e8f0; border-radius: 16rpx;
  font-size: 30rpx; color: #1a202c;
  transition: border-color 0.2s;
}
.field input:focus {
  border-color: #2f6bff; background: #ffffff;
}
.field .hint {
  display: block; margin-top: 14rpx;
  font-size: 24rpx; color: #94a3b8; line-height: 1.7; padding: 0 4rpx;
}

.reg-btn {
  margin-top: 70rpx; border-radius: 50rpx;
  font-size: 33rpx; font-weight: 600;
  height: 96rpx; line-height: 96rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 16rpx 36rpx -10rpx rgba(39,75,214,.5);
}
.skip-row { margin-top: 48rpx; text-align: center; }
.skip-text { font-size: 28rpx; color: #94a3b8; }

.result {
  margin-top: 50rpx; text-align: center;
  padding: 80rpx 48rpx;
}
.res-icon { font-size: 100rpx; }
.res-title { font-size: 36rpx; font-weight: 700; margin-top: 24rpx; color: #0f1b33; }
.res-msg {
  font-size: 27rpx; color: #7a8499; margin-top: 18rpx;
  line-height: 1.7; padding: 0 20rpx;
}
