.reg-wrap { padding: 100rpx 48rpx 60rpx; }
.logo { font-size: 48rpx; font-weight: 600; text-align: center; }
.sub { color: #9aa0a6; text-align: center; margin-top: 16rpx; font-size: 26rpx; }

.err-banner {
  margin-top: 30rpx; padding: 16rpx 24rpx;
  background: #fff3e0; border-radius: 12rpx;
  border-left: 6rpx solid #ff976a;
}
.err-banner text { font-size: 24rpx; color: #e65100; line-height: 1.5; }

.field { margin-top: 24rpx; }
.field .lbl { display: block; font-size: 26rpx; color: #9aa0a6; margin-bottom: 10rpx; }
.field input {
  width: 100%; padding: 20rpx 24rpx;
  background: #fafbfc; border: 1rpx solid #e6e8eb; border-radius: 12rpx;
  font-size: 28rpx;
}

.reg-btn {
  margin-top: 60rpx; border-radius: 48rpx;
  font-size: 32rpx; height: 88rpx; line-height: 88rpx;
}
.skip-row { margin-top: 40rpx; text-align: center; }
.skip-text { font-size: 28rpx; color: #9aa0a6; }

.result { margin-top: 40rpx; text-align: center; padding: 60rpx 40rpx; }
.res-icon { font-size: 90rpx; }
.res-title { font-size: 34rpx; font-weight: 600; margin-top: 16rpx; }
.res-msg { font-size: 26rpx; color: #9aa0a6; margin-top: 12rpx; line-height: 1.6; }
