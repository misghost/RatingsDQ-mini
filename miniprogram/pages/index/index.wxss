.loading { text-align: center; padding: 100rpx; color: #9aa0a6; }

/* 未登录欢迎页 */
.guest-wrap { padding-bottom: 180rpx; }
.guest-hero { padding: 60rpx 48rpx 40rpx; background: linear-gradient(135deg, #07c160, #06ad56); }
.guest-logo { font-size: 44rpx; font-weight: 700; color: #fff; text-align: center; }
.guest-desc { font-size: 26rpx; color: rgba(255,255,255,0.85); text-align: center; margin-top: 20rpx; line-height: 1.6; }
.demo-hint { text-align: center; font-size: 24rpx; color: #9aa0a6; padding: 16rpx 0; }
.login-cta {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 20rpx 48rpx; background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.login-cta .btn-primary {
  width: 100%; border-radius: 48rpx; font-size: 32rpx;
  height: 88rpx; line-height: 88rpx; background: #07c160; color: #fff;
}

.summary {
  display: flex;
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx 0;
}
.sum-item { flex: 1; text-align: center; }
.num { display: block; font-size: 40rpx; font-weight: 600; }
.lbl { font-size: 22rpx; color: #9aa0a6; }

.filters { display: flex; margin: 8rpx 24rpx; }
.filter {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #5a6066;
  background: #fff;
  margin-right: 12rpx;
  border-radius: 12rpx;
}
.filter:last-child { margin-right: 0; }
.filter.active { color: #07c160; font-weight: 600; background: #e8f8ef; }

.empty { text-align: center; color: #9aa0a6; padding: 80rpx; }

.rating-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.subject { font-size: 30rpx; font-weight: 600; }
.tag { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 20rpx; }

.row { display: flex; justify-content: space-between; padding: 6rpx 0; font-size: 26rpx; }
.k { color: #9aa0a6; }
.v { color: #1f2329; }
