<!-- 未登录：功能介绍 + 示例数据 + 登录引导 -->
<view wx:if="{{!loggedIn}}">
  <view class="hero">
    <view class="brand">评级到期提醒</view>
    <view class="desc">实时跟踪客户信用评级到期情况，自动提醒即将过期与已过期项目，助您及时续做、避免遗漏。</view>
  </view>

  <view class="stat-grid">
    <view class="stat"><text class="n" style="color:#e5484d">{{summary.overdue}}</text><text class="l">已过期</text></view>
    <view class="stat"><text class="n" style="color:#f5821f">{{summary.due}}</text><text class="l">即将到期</text></view>
    <view class="stat"><text class="n" style="color:#18a058">{{summary.upcoming}}</text><text class="l">有效期内</text></view>
    <view class="stat"><text class="n">{{summary.total}}</text><text class="l">合计</text></view>
  </view>

  <view class="chips">
    <view wx:for="{{filters}}" wx:key="key" class="chip {{active===item.key ? 'on' : ''}}" data-key="{{item.key}}" bindtap="switchFilter">{{item.label}}</view>
  </view>

  <view class="card" style="text-align:center;color:#8a9099;font-size:24rpx;">（当前为示例数据，登录后查看您的专属数据）</view>

  <view style="padding:24rpx 48rpx 60rpx;">
    <button class="btn btn-primary btn-block" bindtap="goToLogin">立即登录，查看我的数据</button>
  </view>

  <view wx:for="{{list}}" wx:key="contract_no" class="card rating">
    <view class="rating-top">
      <text class="subject">{{item.subject}}</text>
      <text class="tag" style="color:{{item.statusColor}};background:{{item.statusBg}}">{{item.statusLabel}}</text>
    </view>
    <view class="row"><text class="k">合同号</text><text class="v">{{item.contract_no}}</text></view>
    <view class="row"><text class="k">债务类型</text><text class="v">{{item.debt_type || '—'}}</text></view>
    <view class="row"><text class="k">项目类型</text><text class="v">{{item.project_type || '—'}}</text></view>
    <view class="row"><text class="k">到期日</text><text class="v">{{item.expiry}}</text></view>
    <view class="row"><text class="k">提醒日</text><text class="v">{{item.remind}}</text></view>
    <view class="row" wx:if="{{item.left !== null}}"><text class="k">剩余</text><text class="v" style="color:{{item.statusColor}}">{{item.left >= 0 ? item.left + ' 天' : '已超 ' + (-item.left) + ' 天'}}</text></view>
  </view>
</view>

<!-- 已登录 -->
<block wx:if="{{loggedIn}}">
  <view wx:if="{{!ready && loading}}" class="loading">加载中…</view>

  <block wx:else>
    <view class="stat-grid">
      <view class="stat"><text class="n" style="color:#e5484d">{{summary.overdue}}</text><text class="l">已过期</text></view>
      <view class="stat"><text class="n" style="color:#f5821f">{{summary.due}}</text><text class="l">即将到期</text></view>
      <view class="stat"><text class="n" style="color:#18a058">{{summary.upcoming}}</text><text class="l">有效期内</text></view>
      <view class="stat"><text class="n">{{summary.total}}</text><text class="l">合计</text></view>
    </view>

    <view style="margin:8rpx 24rpx;">
      <input class="search" placeholder="搜索客户名称 / 合同号" value="{{search}}" bindinput="onSearch" />
    </view>

    <view class="chips">
      <view wx:for="{{filters}}" wx:key="key" class="chip {{active===item.key ? 'on' : ''}}" data-key="{{item.key}}" bindtap="switchFilter">{{item.label}}</view>
      <view wx:for="{{sorts}}" wx:key="key" class="chip {{sort===item.key ? 'on' : ''}}" data-key="{{item.key}}" bindtap="setSort">{{item.label}}</view>
    </view>

    <view wx:if="{{list.length===0}}" class="empty">暂无匹配记录</view>

    <view wx:for="{{list}}" wx:key="contract_no" class="card rating {{item.renewed ? 'renewed' : ''}}">
      <view class="rating-top">
        <text class="subject">{{item.subject}}</text>
        <text class="tag" style="color:{{item.statusColor}};background:{{item.statusBg}}">{{item.renewed ? '已续期' : item.statusLabel}}</text>
      </view>
      <view class="row"><text class="k">合同号</text><text class="v">{{item.contract_no}}</text></view>
      <view class="row"><text class="k">债务类型</text><text class="v">{{item.debt_type || '—'}}</text></view>
      <view class="row"><text class="k">项目类型</text><text class="v">{{item.project_type || '—'}}</text></view>
      <view class="row"><text class="k">到期日</text><text class="v">{{item.expiry}}</text></view>
      <view class="row"><text class="k">提醒日</text><text class="v">{{item.remind}}</text></view>
      <view class="row" wx:if="{{item.left !== null}}"><text class="k">剩余</text><text class="v" style="color:{{item.statusColor}}">{{item.left >= 0 ? item.left + ' 天' : '已超 ' + (-item.left) + ' 天'}}</text></view>
      <view style="margin-top:16rpx;" wx:if="{{!item.renewed}}">
        <button class="btn btn-grey btn-block" style="height:64rpx;font-size:26rpx;border-radius:999rpx;" data-id="{{item.id}}" bindtap="renew">标记已续期 / 已重评</button>
      </view>
    </view>

    <view class="card sec-card" bindtap="goChangePw">
      <view class="sec-left">
        <text class="sec-title">账号安全</text>
        <text class="sec-sub">修改登录密码，防止账号被冒用</text>
      </view>
      <text class="sec-arrow">›</text>
    </view>

    <view class="card logout-card" bindtap="logout">
      <view class="sec-left">
        <text class="logout-text">退出账号</text>
        <text class="sec-sub">退出后可更换其他账号登录，或用于解除卡顿</text>
      </view>
      <text class="sec-arrow">›</text>
    </view>
  </block>
</block>
